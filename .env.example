# Copy this file to .env and fill in the URL (do not commit .env).
#
# 1. In Google Sheets: Extensions → Apps Script
# 2. Paste google-apps-script/Code.gs, save
# 3. Deploy → New deployment → Select type: Web app
#    Execute as: Me  |  Who has access: Anyone
# 4. Copy the Web app URL (ends with /exec) into the line below
#
# Local / non-Netlify: set the web app URL here or in public/sheets-webapp.json.
#
# Netlify: netlify.toml sets VITE_REGISTRATION_API=/api/register at build time.
# In Netlify → Environment variables, set the script URL for the serverless function
# (name can be any of these):
#   GOOGLE_SHEETS_WEB_APP_URL
#   VITE_GOOGLE_SHEETS_WEB_APP_URL
#   APPS_SCRIPT_WEB_APP_URL
#   WEB_APP_URL
# Then trigger a new deploy (Clear cache and deploy) so the function picks it up.

VITE_GOOGLE_SHEETS_WEB_APP_URL=
